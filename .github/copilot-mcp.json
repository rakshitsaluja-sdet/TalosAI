{
  "version": "1.0",
  "mcpServers": [
    {
      "name": "playwright",
      "command": "node",
      "args": ["playwright-mcp/server.js"],
      "autoStart": true,
      "description": "Playwright MCP server for browser automation"
    }
  ],
  "agentConfig": {
    "agentDirectory": ".github/agents",
    "defaultAgent": "regression.agent",
    "enabledAgents": [
      "api-testing.agent",
      "code-review.agent",
      "regression.agent",
      "self-healing.agent",
      "story-to-test.agent"
    ]
  }
}